# Frontend runtime endpoints
VITE_GATEWAY_SERVER_URL=http://localhost:3001
VITE_LOCAL_API_URL=http://localhost:8000

# On-chain ProofRegistry (Base Sepolia)
# Filled automatically when running:
#   cd contracts && npx hardhat run scripts/deploy.ts --network baseSepolia
VITE_PROOF_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000

# ERC-8021 Builder Code Attribution
# Register at: https://base.dev → Settings → Builder Code
# Default "ai-router" is used for development if not set.
VITE_BUILDER_CODE=ai-router
