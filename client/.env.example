# Gateway server
GATEWAY_SERVER_URL=http://localhost:3001

# Ollama (local LLM)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# Optional overrides
LOCAL_API_PORT=8000

# 0G Compute Inference (optional — enables AI-powered smart routing)
# The integration uses an OpenAI-compatible endpoint.
# Option A) Together AI (easiest): get a free API key at https://api.together.ai
#   ZERO_G_BASE_URL=https://api.together.xyz/v1
# Option B) Any other OpenAI-compatible inference provider
# Docs: https://docs.0g.ai/build-with-0g/compute-network/overview
ZERO_G_API_KEY=
ZERO_G_BASE_URL=https://api.together.xyz/v1
ZERO_G_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo
