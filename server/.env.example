# Server
PORT=3001
NODE_ENV=development

# x402 Payment
RESOURCE_WALLET_ADDRESS=0xYourWalletOnBaseSepolia
FACILITATOR_URL=https://x402.org/facilitator
NETWORK=eip155:84532

# AI Provider API Keys
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
DEEPSEEK_API_KEY=sk-...
GEMINI_API_KEY=AIza...

# Headless Autonomous Payment Demo
# Run with: cd server && tsx scripts/headless-demo.ts
# Demonstrates fully autonomous x402 payment flow — no browser, no manual wallet clicks.
# The private key wallet must hold USDC on Base Sepolia.
HEADLESS_PRIVATE_KEY=0xYourPrivateKeyWithUsdcBalance
HEADLESS_PROVIDER=haiku
HEADLESS_GATEWAY_URL=http://localhost:3001
HEADLESS_MESSAGE=Explain what x402 is in one sentence.
